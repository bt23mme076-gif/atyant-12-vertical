# Copy this file to .env and fill in real values. Never commit the real .env.

# ─── Required ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/atyant
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins. Includes the current
# production frontend domains plus local dev ports — update this list (not
# src/app.js) whenever an allowed origin changes.
CORS_ORIGINS=https://atyantjee.vercel.app,https://jee.atyant.in,http://localhost:3000,http://localhost:5173

# ─── Admin seed (src/scripts/seedAdmin.js) ──────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# ─── LLM providers (chat / decision engine) ─────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ─── Cashfree payments ───────────────────────────────────────────────────
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# 'sandbox' or 'production'
CASHFREE_ENVIRONMENT=sandbox

# ─── Referral system ─────────────────────────────────────────────────────
REFERRAL_UNLOCK_THRESHOLD=3
