# Server
PORT=5000
NODE_ENV=development

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://www.atyant.in

# MongoDB
MONGODB_URI=mongodb://localhost:27017/atyant

# JWT
JWT_SECRET=replace-this-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Seed admin (used by `npm run seed:admin` only)
SEED_ADMIN_EMAIL=admin@atyant.in
SEED_ADMIN_PASSWORD=ChangeMeNow!

# GROQ API (for chat widget)
GROQ_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant


